Understanding Data Visualization

 import matplotlib.pyplot as plt
import seaborn as sns

# Visualize the top 10 categories by installs with annotations
plt.figure(figsize=(15, 8))
sns.barplot(x=installs_by_category.head(10).index, y=installs_by_category.head(10).values, hue=installs_by_category.head(10).index, palette='viridis', legend=False)
plt.title('Top 10 App Categories by Total Installs (with Annotations)')
plt.xlabel('Category')
plt.ylabel('Total Installs')
plt.xticks(rotation=45, ha='right')

# Add annotations
for index, row in enumerate(installs_by_category.head(10).values):
    plt.text(index, row + 0.05 * installs_by_category.head(10).max(), f'{row:,.0f}', color='black', ha='center', va='bottom', fontsize=9)

plt.tight_layout()
plt.show()
import matplotlib.pyplot as plt
